# ======================================================================
# INTELLIGENT Grid Operator Middleware V2 - Environment Configuration Template
# ======================================================================
# Copy this file to '.env' and adjust the variables to match your environment.
# E.g., cp .env.sample .env

# ----------------------------------------------------------------------
# 1. Google Cloud Platform (GCP) Configurations
# ----------------------------------------------------------------------
# Your Google Cloud Project ID
GCP_PROJECT_ID=intelligent-grid-operator

# The GCP Pub/Sub Pull Subscription Name to pull messages from
GCP_SUBSCRIPTION_NAME=grid-operator-sub-v2

# The GCP Pub/Sub Topic where audit and tracking records will be logged for BigQuery
GCP_AUDIT_LOG_TOPIC=store_data

# ----------------------------------------------------------------------
# 2. Performance and Reliability Settings
# ----------------------------------------------------------------------
# Maximum number of unacknowledged messages pulled from Pub/Sub concurrently (Backpressure Control)
FLOW_CONTROL_MAX_MESSAGES=100

# The initial acknowledgement deadline in seconds (can be auto-extended by Pub/Sub client)
ACK_DEADLINE_SECONDS=60

# ----------------------------------------------------------------------
# 3. Downstream Pilot Routing Endpoint (SINGLE HTTP POST)
# ----------------------------------------------------------------------
# Target single endpoint URL used for all message types:
ENDPOINT=https://api.intelligent-pilot.eu/api/v2/messages

# ----------------------------------------------------------------------
# 4. API Key Configuration
# ----------------------------------------------------------------------
# API key sent in the x-api-key header:
ENDPOINT_API_KEY=api-key-secure-v2

# ----------------------------------------------------------------------
# 5. Optional Routing Metadata
# ----------------------------------------------------------------------
# The middleware sends entityId, topicName, topicOwner, topicVersion and fqcn
# as part of the downstream gateway request body.
ENTITY_ID=612
ROUTING_TOPIC_NAME_METERING=SCN-PT-01_METERING
ROUTING_TOPIC_OWNER_METERING=E-REDES
ROUTING_TOPIC_VERSION_METERING=1.0
ROUTING_FQCN_METERING=eu.energygrid.messages.Metering

# ----------------------------------------------------------------------
# 6. Runtime Mode Configuration
# ----------------------------------------------------------------------
# Enable or disable Pub/Sub message ingestion
PUBSUB_ENABLED=true

# Enable or disable the HTTP listener mode
HTTP_LISTENER_ENABLED=true
HTTP_LISTENER_PORT=8080
HTTP_LISTENER_PATH=/message

# ----------------------------------------------------------------------
# 7. Logging Configuration
# ----------------------------------------------------------------------
# Logging level (debug, info, warn, error)
LOG_LEVEL=info
