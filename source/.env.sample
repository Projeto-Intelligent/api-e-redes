# ======================================================================
# INTELLIGENT Grid Operator Middleware V2 - Environment Configuration Template
# ======================================================================
# Copy this file to '.env' and adjust the variables to match your environment.
# E.g., cp .env.sample .env

# ----------------------------------------------------------------------
# 1. Google Cloud Platform (GCP) Configurations
# ----------------------------------------------------------------------
# Your Google Cloud Project ID
GCP_PROJECT_ID=intelligent-grid-operator

# The GCP Pub/Sub Pull Subscription Name to pull messages from
GCP_SUBSCRIPTION_NAME=grid-operator-sub-v2

# The GCP Pub/Sub Topic where audit and tracking records will be logged for BigQuery
GCP_AUDIT_LOG_TOPIC=store_data

# ----------------------------------------------------------------------
# 2. Performance and Reliability Settings
# ----------------------------------------------------------------------
# Maximum number of unacknowledged messages pulled from Pub/Sub concurrently (Backpressure Control)
FLOW_CONTROL_MAX_MESSAGES=100

# The initial acknowledgement deadline in seconds (can be auto-extended by Pub/Sub client)
ACK_DEADLINE_SECONDS=60

# ----------------------------------------------------------------------
# 3. Downstream Pilot Routing Endpoints (HTTP POST)
# ----------------------------------------------------------------------
# Target endpoint URLs for routing each specific exchange ID payload:
ENDPOINT_METERING=https://api.intelligent-pilot.eu/v2/metering
ENDPOINT_GRID_SIGNAL=https://api.intelligent-pilot.eu/v2/grid-signals
ENDPOINT_P2P_MARKET_DATA=https://api.intelligent-pilot.eu/v2/p2p-market
ENDPOINT_DYNAMIC_GRID_TARIFF=https://api.intelligent-pilot.eu/v2/grid-tariffs
ENDPOINT_TRANSACTION_VALIDATION=https://api.intelligent-pilot.eu/v2/transaction-validation

# ----------------------------------------------------------------------
# 4. Security & Authorization Tokens (EWDS Integration)
# ----------------------------------------------------------------------
# Bearer Tokens used to authorize HTTP POST requests to downstream pilot endpoints:
TOKEN_METERING=token-secure-metering-v2
TOKEN_GRID_SIGNAL=token-secure-grid-signal-v2
TOKEN_P2P_MARKET_DATA=token-secure-p2p-v2
TOKEN_DYNAMIC_GRID_TARIFF=token-secure-tariffs-v2
TOKEN_TRANSACTION_VALIDATION=token-secure-validation-v2

# ----------------------------------------------------------------------
# 5. Logging Configuration
# ----------------------------------------------------------------------
# Logging level (debug, info, warn, error)
LOG_LEVEL=info
